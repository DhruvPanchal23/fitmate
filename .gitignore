```gitignore
# ==========================
# Dependencies
# ==========================
node_modules/
**/node_modules/

# ==========================
# Build Output
# ==========================
dist/
build/
.next/
.expo/
.expo-shared/
coverage/
.cache/
out/
web-build/

# ==========================
# TypeScript
# ==========================
*.tsbuildinfo

# ==========================
# Environment Files
# ==========================
.env
.env.*
!.env.example

# ==========================
# Logs
# ==========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ==========================
# Temporary Files
# ==========================
tmp/
temp/
*.tmp

# ==========================
# IDE Files
# ==========================
.vscode/
!.vscode/extensions.json
.idea/

# ==========================
# OS Files
# ==========================
.DS_Store
Thumbs.db

# ==========================
# Expo / React Native
# ==========================
.expo/
.expo-shared/
metro-cache/

# ==========================
# Prisma
# ==========================
prisma/dev.db
prisma/dev.db-journal

# ==========================
# Sentry
# ==========================
.sentryclirc

# ==========================
# Local Certificates
# ==========================
*.pem
*.key
*.crt

# ==========================
# Firebase
# ==========================
google-services.json
GoogleService-Info.plist

# ==========================
# Misc
# ==========================
*.pid
*.seed
*.pid.lock
```
