```env
# ======================================
# Application
# ======================================

NODE_ENV=development
PORT=3000

# ======================================
# Database
# ======================================

DATABASE_URL=postgresql://username:password@localhost:5432/fitmate?schema=public

# ======================================
# JWT Authentication
# ======================================

JWT_SECRET=replace_with_secure_secret
JWT_EXPIRATION=7d

# ======================================
# AI Providers
# ======================================

GEMINI_API_KEY=your_gemini_api_key

OPENAI_API_KEY=your_openai_api_key

ANTHROPIC_API_KEY=your_anthropic_api_key

# ======================================
# Error Monitoring
# ======================================

SENTRY_DSN=your_sentry_dsn

RELEASE_VERSION=fitmate-v1.0.0

# ======================================
# Email Service
# ======================================

SMTP_HOST=smtp.example.com

SMTP_PORT=587

SMTP_USER=user@example.com

SMTP_PASSWORD=your_password

SMTP_FROM=noreply@fitmate.com

# ======================================
# Admin
# ======================================

ADMIN_URL=http://localhost:5173

ADMIN_DEFAULT_EMAIL=admin@example.com

ADMIN_DEFAULT_PASSWORD=change_this_password

# ======================================
# Mobile
# ======================================

EXPO_PUBLIC_API_URL=http://localhost:3000

EXPO_PUBLIC_APP_NAME=FitMate

# ======================================
# Storage
# ======================================

STORAGE_PROVIDER=local

STORAGE_BUCKET=fitmate

# ======================================
# Cache
# ======================================

REDIS_URL=redis://localhost:6379

# ======================================
# Security
# ======================================

CORS_ORIGIN=http://localhost:8081,http://localhost:5173

RATE_LIMIT_WINDOW_MS=60000

RATE_LIMIT_MAX=60

# ======================================
# Monitoring
# ======================================

PROMETHEUS_ENABLED=true

METRICS_PATH=/metrics

# ======================================
# Feature Flags
# ======================================

ENABLE_AI=true

ENABLE_TRAVEL_MODE=true

ENABLE_ANALYTICS=true

ENABLE_NOTIFICATIONS=true
```
