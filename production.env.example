# ==========================================
# FitMate Production Environment Template
# ==========================================

# 1. Server Configuration
PORT=3000
NODE_ENV=production

# 2. Database Connection
# Replace with your production PostgreSQL URL (e.g. AWS RDS or Supabase)
# It is highly recommended to append ?sslmode=require for secure connections
DATABASE_URL="postgresql://postgres:SECURE_PASSWORD@prod-db-host:5432/fitmate?schema=public"

# 3. Security & Sessions
# Generate a random high-entropy 256-bit string for signing tokens
JWT_SECRET="YOUR_HIGH_ENTROPY_JWT_SECRET_STRING"
JWT_EXPIRATION="7d"

# 4. Observability & Sentry
# Provide Sentry DSN key to enable production error and crash tracking
SENTRY_DSN="https://your-sentry-key@o123456.ingest.sentry.io/123456"
RELEASE_VERSION="fitmate-backend@1.0.0"

# 5. AI API Integrations
# Provide at least one API key to unlock AI Coach and Food Scan functions
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere..."
OPENAI_API_KEY="sk-proj-YourOpenAIApiKeyHere..."
ANTHROPIC_API_KEY="sk-ant-YourAnthropicApiKeyHere..."
